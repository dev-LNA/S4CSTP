  <property name="styleSheet">
   <string notr="true">QLineEdit,
QSpinBox,
QDoubleSpinBox,
QDateTimeEdit,
QComboBox {
    background-color: rgb(255, 255, 255);
	font: 8pt &quot;Arial&quot;;
	color: rgb(0, 0, 0);
}

QLabel[led=true]{
background-color: rgb(0, 50, 0);
border-style: solid;
border-width: 2px;
border-color: rgb(255, 255, 255);
border-radius: 12px;
min-height: 20px;
max-height: 20px;
min-width: 20px;
max-width: 20px;
}

/* ===================================  */

QLabel[led_status=off]{
background-color: rgb(0, 50, 0);
}

QLabel[led_status=on]{
background-color: rgb(0, 255, 0);
}

QLabel[led_status=error]{
background-color: rgb(255, 0, 0);
}

QLabel[led_status=warn]{
background-color: rgb(241, 241, 120);
}

QLabel[text_label=true]{
font: 12pt &quot;Arial&quot;;
color: rgb(255, 255, 255);
}

/* ===================================  */

QPushButton {    
	background-color: rgb(0, 170, 255);
    color: white;   
    border-radius: 4px;
	min-height: 25px;
	font: 75 8pt &quot;MS Shell Dlg 2&quot;;
}

QPushButton:pressed {
    background-color: #1e5ea8;
    padding-left: 2px;
    padding-top: 2px;
}

QPushButton:disabled {
background-color: rgb(143, 143, 143);
}

QPushButton:hover {   
	border: 1px solid #0b4d0f;
}

QPushButton:checked {
    padding-left: 2px;
    padding-top: 2px;	
	background-color: rgb(0, 97, 145);
	
}</string>
